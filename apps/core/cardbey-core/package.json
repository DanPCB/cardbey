{
  "name": "@cardbey/core",
  "private": true,
  "version": "1.0.0",
  "description": "Cardbey Core API - Central backend for all Cardbey services. npm lifecycle: prestart runs only before the start script (npm start), not before dev (npm run dev).",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "prestart": "node --import tsx scripts/prisma-bootstrap.js",
    "start": "node --import tsx/esm src/server.js",
    "build": "npx prisma generate --schema prisma/schema.prisma",
    "postinstall": "echo 'Running postinstall for sharp...' && npm install --include=optional sharp && npm rebuild --platform=linux --arch=x64 sharp || echo 'Warning: Sharp rebuild failed - will use lazy loading fallback' && echo 'Generating Prisma client...' && npx prisma generate --schema prisma/schema.prisma",
    "dev": "node scripts/with-role.mjs dev-api",
    "dev:health": "npm-run-all --parallel dev dev:health:poll",
    "dev:health:poll": "node scripts/poll-health.js",
    "db:ping": "node scripts/db-ping.js",
    "db:doctor": "node scripts/db-doctor.mjs",
    "check:env": "node scripts/check-env.js",
    "dev:api": "node scripts/check-port.mjs && node scripts/with-role.mjs dev-api",
    "dev:worker": "node scripts/with-role.mjs dev-worker",
    "dev:all": "npm-run-all --parallel dev:api dev:worker",
    "start:api": "node scripts/with-role.mjs start-api",
    "start:worker": "node scripts/with-role.mjs start-worker",
    "start:all": "npm-run-all --parallel start:api start:worker",
    "db:generate": "prisma generate --schema prisma/sqlite/schema.prisma",
    "db:generate:sqlite": "prisma generate --schema prisma/sqlite/schema.prisma",
    "db:generate:sqlite:retry": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma-generate-sqlite.ps1",
    "db:generate:postgres": "node scripts/run-postgres-prisma.js generate",
    "db:migrate": "node scripts/run-postgres-prisma.js migrate dev",
    "prisma:migrate:postgres": "node scripts/run-postgres-prisma.js migrate deploy",
    "db:studio": "prisma studio --schema prisma/sqlite/schema.prisma",
    "db:reset": "node scripts/run-postgres-prisma.js migrate reset",
    "db:push": "prisma db push --schema prisma/sqlite/schema.prisma",
    "db:push:test": "cross-env DATABASE_URL=file:../test.db npx prisma db push --schema prisma/sqlite/schema.prisma --accept-data-loss",
    "setup": "npm install && npx prisma generate --schema prisma/sqlite/schema.prisma",
    "smoke": "node scripts/smoke.js",
    "test:playlist": "node scripts/test/playlist-full.js",
    "smoke:dev": "cross-env API_BASE=http://localhost:3001 node scripts/smoke.js",
    "scan:missing-media": "node scripts/scan-missing-media.js",
    "pretest": "cross-env PRISMA_CLIENT_ENGINE_TYPE=binary NODE_ENV=test DATABASE_URL=file:./prisma/test.db npx prisma generate --schema prisma/sqlite/schema.prisma && cross-env PRISMA_CLIENT_ENGINE_TYPE=binary NODE_ENV=test DATABASE_URL=file:./prisma/test.db npx prisma db push --schema prisma/sqlite/schema.prisma --accept-data-loss",
    "test": "cross-env PRISMA_CLIENT_ENGINE_TYPE=binary NODE_ENV=test DATABASE_URL=file:./prisma/test.db vitest run",
    "test:staging-sanity": "cross-env NODE_ENV=test DATABASE_URL=file:../test.db vitest run src/lib/agentPlanner.test.js src/test/contactsSync.api.test.js src/test/e2e/foundation1-closeout.e2e.test.js --pool=forks --no-file-parallelism",
    "e2e:foundation1:setup": "npm run db:push:test && node scripts/e2e-foundation1-setup.js",
    "test:e2e:foundation1": "npm run db:push:test && cross-env NODE_ENV=test DATABASE_URL=file:../test.db vitest run src/test/e2e/foundation1-closeout.e2e.test.js",
    "test:e2e:foundation2": "cross-env NODE_ENV=test DATABASE_URL=file:../test.db vitest run src/test/e2e/foundation2-closeout.e2e.test.js",
    "test:e2e:foundation3": "cross-env NODE_ENV=test DATABASE_URL=file:../test.db vitest run src/test/e2e/foundation3-closeout.e2e.test.js",
    "test:e2e:m3-checkpoints": "cross-env NODE_ENV=test DATABASE_URL=file:../test.db vitest run src/test/e2e/m3-checkpoints-closeout.e2e.test.js",
    "backfill:handles": "node src/scripts/backfillUserHandles.js",
    "backfill:store-slugs": "node src/scripts/backfillStoreSlugs.js",
    "backfill:draft-generation-run-id": "node scripts/backfillDraftStoreGenerationRunId.js",
    "backfill:mi-signage": "tsx scripts/backfillMIForSignage.js",
    "rag:ingest": "tsx scripts/ingestRagKnowledge.ts",
    "rag:ingest:reports": "tsx scripts/ingestRagReports.ts",
    "reports:daily": "tsx scripts/generateDailyReports.ts",
    "reports:daily-all": "tsx scripts/generateDailyReports.ts",
    "reports:test-pdf": "node scripts/testReportPdf.js",
    "verify:feature-flag": "tsx scripts/verify-feature-flag.js",
    "seed:mi-video-templates": "node scripts/seedMiVideoTemplates.js",
    "seed:ingest": "node scripts/seed-ingest.js",
    "fix:media-base-url": "node scripts/fixMediaBaseUrl.js",
    "fix-media-urls": "node scripts/fix-media-urls.js",
    "normalize:media-urls-relative": "node scripts/normalize-stored-media-urls-to-relative.mjs",
    "create:admin": "node scripts/createAdmin.js",
    "admin:promote": "node scripts/promoteUserRole.js",
    "test:marketing-agent": "node scripts/marketing-agent-test-flow.js",
    "e2e:french-baguette": "node ../../../scripts/e2e-french-baguette.js"
  },
  "keywords": [
    "cardbey",
    "api",
    "backend"
  ],
  "author": "Cardbey Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@aws-sdk/client-sqs": "^3.937.0",
    "@aws-sdk/s3-request-presigner": "^3.1007.0",
    "@langchain/core": "1.1.36",
    "@langchain/openai": "1.3.1",
    "@prisma/client": "^6.18.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cuid": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "langchain": "^0.3.30",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.16",
    "openai": "^6.9.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.15.0",
    "prisma": "^6.18.0",
    "puppeteer": "^23.11.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "stripe": "^22.0.1",
    "tsx": "^4.21.0",
    "unsplash-js": "^7.0.20",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.0",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
