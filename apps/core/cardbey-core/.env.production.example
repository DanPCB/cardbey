# Copy to Render (or merge) as environment variables. Do not commit secrets.
#
# Pre-deploy checklist (Render service → Environment):
#   Required: NODE_ENV=production, DATABASE_URL=postgresql://..., JWT_SECRET, PUBLIC_BASE_URL, FRONTEND_URL,
#             OPENAI_API_KEY, XAI_API_KEY
#   LLM routing: AGENT_LLM_PROVIDER, AGENT_LLM_MODEL, PERFORMER_INTAKE_*, PLANNER_TIMEOUT_MS (see below)
#   Feature flags: USE_LLM_TASK_PLANNER, ENABLE_OPENCLAW_AGENT_RUNTIME, OPENCLAW_MISSION_STEPS, LANGCHAIN_ENABLED,
#                  ENABLE_PROACTIVE_CAMPAIGN_RUNWAY, ENABLE_OPENCLAW_REAL_CAMPAIGN_APIS, ALLOW_CONCURRENT_MISSION_STEPS
#   CrewAI: CREWAI_ENABLED=false until Python/pip is on the build image (render.yaml pip step is non-fatal).
#
# Post-deploy verification (first deploy):
#   1) Render logs: [SERVER] PUBLIC_BASE_URL: https://your-dashboard-domain.com
#      [ProactiveStep] agent dispatch mode: OpenClaw (OPENCLAW_MISSION_STEPS=true)
#      or dispatchTool if OpenClaw not enabled
#   2) curl https://your-api-domain.onrender.com/health
#   3) curl -X POST https://your-api-domain.onrender.com/api/performer/intake \
#        -H "Authorization: Bearer $TOKEN" -H "Content-Type: application/json" \
#        -d '{"message": "Launch a marketing campaign"}'
#
# Prisma: this repo keeps separate schema files (prisma/postgres vs sqlite). On Render,
# set DATABASE_URL to a postgresql:// URL. The Render build command must run
# `npx prisma generate --schema prisma/postgres/schema.prisma` after npm install
# so the client in node_modules/.prisma/client-gen matches Postgres (see render.yaml).

# Core
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=...
FRONTEND_URL=https://your-dashboard.onrender.com
# Public URLs for QR codes and promo landing pages — use the dashboard (frontend) origin, not the API host.
PUBLIC_BASE_URL=https://your-dashboard.onrender.com

# LLM
OPENAI_API_KEY=...
AGENT_LLM_PROVIDER=xai
AGENT_LLM_MODEL=grok-3-beta
XAI_API_KEY=...
PERFORMER_INTAKE_LLM_MODEL=gpt-4o-mini
PERFORMER_INTAKE_LLM_PROVIDER=openai
PERFORMER_INTAKE_PLANNER_MODEL=gpt-4o-mini
PLANNER_TIMEOUT_MS=20000

# OpenClaw
ENABLE_OPENCLAW_AGENT_RUNTIME=true
OPENCLAW_MISSION_STEPS=true
OPENCLAW_APPROVALS_ENABLED=true
OPENCLAW_WEB_ENABLED=true
OPENCLAW_MEMORY_ENABLED=true
OPENCLAW_ORCHESTRATOR_AUTO_REFLECT_ON_FAILURE=true

# LangChain
LANGCHAIN_ENABLED=true

# CrewAI — false until Render build has Python/pip (Node images often lack pip; render.yaml pip is non-fatal)
CREWAI_ENABLED=false

# Feature flags
ENABLE_OPENCLAW_REAL_CAMPAIGN_APIS=true
USE_LLM_TASK_PLANNER=true
ENABLE_PROACTIVE_CAMPAIGN_RUNWAY=true
ENABLE_PERFORMER_INTAKE_V2_SHADOW=1

# Mission
ALLOW_CONCURRENT_MISSION_STEPS=true

# Render: prefer `npm start` (not raw `node src/server.js`) so `prestart` runs Prisma bootstrap.
