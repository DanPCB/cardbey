# Database
DATABASE_URL=\
file:./prisma/dev.db\   # sqlite dev default

# OAuth Providers (optional - set at least one to enable OAuth)
FACEBOOK_CLIENT_ID=\\
FACEBOOK_CLIENT_SECRET=\\
FACEBOOK_REDIRECT_URI=\http://localhost:3001/oauth/facebook/callback\

TIKTOK_CLIENT_KEY=\\
TIKTOK_CLIENT_SECRET=\\
TIKTOK_REDIRECT_URI=\http://localhost:3001/oauth/tiktok/callback\

TWITTER_CLIENT_ID=\\
TWITTER_CLIENT_SECRET=\\
TWITTER_REDIRECT_URI=\http://localhost:3001/oauth/twitter/callback\

# Dev only: Fake OAuth provider (for local testing without real credentials)
# Set to 1 to enable a fake \dev\ provider that shows as configured
# Automatically disabled in production (NODE_ENV=production)
OAUTH_DEV_FAKE=0

# Public URLs (playlist/media bases). getBaseUrlFromRequest prefers Host over env; set API base for CLI/no-Host fallbacks.
# Example LAN API: PUBLIC_API_BASE_URL=http://192.168.1.11:3001
# PUBLIC_BASE_URL=...

# Server Configuration
PORT=3001
NODE_ENV=development
ROLE=api

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174,http://127.0.0.1:5174,http://192.168.1.7:5174

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Contact Sync (Phase 1 MVP)
# Server-controlled keyed HMAC secret (do NOT commit real value). Required to enable contact sync APIs.
CONTACT_SYNC_HMAC_SECRET=change-me

# Phase 2 draft guardrails: vertical image filter + de-generic item names (default off until validated)
ENABLE_DRAFT_GUARDS=false

# Optional: OpenAI
OPENAI_API_KEY=\\

# OCR fallback (Agent Chat only; see docs/OCR_FALLBACK.md)
# When primary (OpenAI Vision) returns refusal/invalid, fallback runs if enabled
# GOOGLE_CLOUD_VISION_ENABLED=false
# GOOGLE_CLOUD_VISION_API_KEY=

# Screen status worker (ping the player device)
SCREENS_PING_PATH=/health
SCREENS_DEFAULT_PORT=5174
SCREENS_TIMEOUT_MS=3000
SCREENS_LOG_EVERY=20
SCREENS_SELF_PING=0

# SAM-3 Configuration (optional - see docs/SAM3_SETUP.md)
SAM3_MODEL_PATH=./models/sam3_hiera_large.pt
SAM3_DEVICE=cuda
# or cpu for development machines

# Email verification (optional – when false or MAIL_HOST unset, verification emails are log-only)
ENABLE_EMAIL_VERIFICATION=false
MAIL_HOST=
MAIL_PORT=
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM_EMAIL=no-reply@cardbey.com
MAIL_FROM_NAME=Cardbey

# Agent chat: when true, user messages that match actionable intent (create, plan, fix, etc.) trigger planner/research.
# When false (default), only explicit Continue/Execute or approval flows dispatch agents; chat is chat-only.
# AUTO_DISPATCH_ON_CHAT=false

# Performer: pre-intake chat agent loop (thought → read-only tools → handoff to Intake V2 classifier). Default off.
# PERFORMER_CHAT_AGENT_LOOP=false
# PERFORMER_AGENT_LOOP_MAX_STEPS=5
# PERFORMER_AGENT_LOOP_MODEL=
# PERFORMER_AGENT_LOOP_PROVIDER=
# Optional: comma-separated subset of tool names (default: market_research,analyze_store,orders_report,generate_social_posts,smart_visual,signage.list-devices)
# PERFORMER_AGENT_LOOP_TOOLS=market_research,orders_report,smart_visual

# Content ingest dataset capture (dev-gated; OFF unless ENABLE_CONTENT_INGEST_LOGS=true)
# ENABLE_CONTENT_INGEST_LOGS=false
# CONTENT_INGEST_RETENTION_DAYS=14
# CONTENT_INGEST_MAX_ROWS_PER_DAY=200
# CONTENT_INGEST_SAMPLE_RATE=1.0
# CONTENT_INGEST_WIPE_WEBSITE_URL=false
# CONTENT_INGEST_EXPORT_MAX_LIMIT=500

# Phase 2 � LLM Task Planning
# Set true to run planTaskGraphForIntent for launch_campaign before intake JSON planner / lightweight fallback.
USE_LLM_TASK_PLANNER=false
# OpenClaw: ENABLE_OPENCLAW_AGENT_RUNTIME gates spawnChildAgent / runOpenClawMission (see apps/core/openclaw/config.ts).
ENABLE_OPENCLAW_AGENT_RUNTIME=false
# When true, agentOrchestrator may route agentHint openclaw steps through childAgentBridge (requires runtime enabled above).
OPENCLAW_MISSION_STEPS=false
LLM_TASK_PLANNED_MISSION_TYPES=launch_campaign

# Content Library (SVGRepo + Brandfetch logo search)
BRANDFETCH_API_KEY=your_brandfetch_api_key_here
SVGREPO_API_KEY=optional_if_needed

# LangChain.js executor (RAG via runRagForMission + step memory); orchestrator routes agentHint "langchain".
LANGCHAIN_ENABLED=false

# Agent execution LLM (used by agentRegistry callAsAgent; market_research -> researcher)
AGENT_LLM_PROVIDER=xai
AGENT_LLM_MODEL=grok-3-beta
