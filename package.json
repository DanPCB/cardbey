{
  "name": "cardbey-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  },
  "scripts": {
    "check:runway": "node scripts/check-single-runway.js",
    "dev:core": "yarn workspace @cardbey/core dev",
